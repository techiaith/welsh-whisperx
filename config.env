# WhisperX Server Configuration
# This file contains non-sensitive configuration and is committed to git
# Sensitive values (tokens, passwords) go in .env.secrets

# Note: WHISPER_MODEL_DEVICE is set in docker-compose files
# - docker-compose.gpu.yml sets WHISPER_MODEL_DEVICE=gpu
# - docker-compose.cpu.yml sets WHISPER_MODEL_DEVICE=cpu

# GPU device indices (which host GPUs to map into containers)
# GPU 1: worker-high + worker-default (shared)
CUDA_DEVICE_INDEX_HIGH=1
CUDA_DEVICE_INDEX_DEFAULT=1
# GPU 0: worker-high-2 (dedicated, overflow for high-priority)
CUDA_DEVICE_INDEX_HIGH_2=0

# Model Configuration
WHISPER_MODEL_NAME=techiaith/whisper-large-ft-cy-en-ct2
WHISPER_MODEL_LANGUAGE=cy
WAV2VEC2_MODEL=DewiBrynJones/wav2vec2-xlsr-53-ft-btb-cv-cvad-cven-wlga-ca

# Performance Configuration
# Skip speaker diarization for audio shorter than this (seconds)
# Set to 0 to always run diarization
DIARIZE_MIN_DURATION_SECONDS=30

# Skip saving output files (srt, vtt, elan, txt) for audio shorter than this (seconds)
# JSON is still saved for debugging. Set to 0 to always save all files.
SAVE_FILES_MIN_DURATION_SECONDS=30

# Skip word-level alignment for audio shorter than this (seconds)
# Without alignment: no word timestamps, no confidence scores. Set to 0 to always align.
ALIGN_MIN_DURATION_SECONDS=30

# Recycle Celery worker processes after N tasks (reloads models each time).
# 0 = never recycle (default, recommended). Set to e.g. 500 if you see GPU memory leaks.
WORKER_MAX_TASKS_PER_CHILD=0

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# File Cleanup Configuration
# Automatically delete old transcription files to prevent disk space issues
CLEANUP_ENABLED=true
FILE_RETENTION_DAYS=14
CLEANUP_SCHEDULE=0 2 * * *
RECORDINGS_DIR=/recordings
