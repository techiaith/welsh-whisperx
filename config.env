# WhisperX Server Configuration
# This file contains non-sensitive configuration and is committed to git
# Sensitive values (tokens, passwords) go in .env.secrets

# Note: WHISPER_MODEL_DEVICE is set in docker-compose files
# - docker-compose.gpu.yml sets WHISPER_MODEL_DEVICE=gpu
# - docker-compose.cpu.yml sets WHISPER_MODEL_DEVICE=cpu

# Model Configuration
WHISPER_MODEL_NAME=DewiBrynJones/whisper-large-v2-ft-btb-cv-cvad-ca-wlga-cy-ct2-2511
WHISPER_MODEL_LANGUAGE=cy
WAV2VEC2_MODEL=DewiBrynJones/wav2vec2-xlsr-53-ft-btb-cv-cvad-cven-wlga-ca

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# File Cleanup Configuration
# Automatically delete old transcription files to prevent disk space issues
CLEANUP_ENABLED=true
FILE_RETENTION_DAYS=14
CLEANUP_SCHEDULE=0 2 * * *
RECORDINGS_DIR=/recordings
